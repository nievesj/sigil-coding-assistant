<idea-plugin require-restart="false">
  <id>com.github.catatafishen.ideagentforcopilot</id>
  <name>AgentBridge</name>
  <vendor email="henrik@westergard.org" url="https://github.com/catatafishen/agentbridge">
    AgentBridge Contributors
  </vendor>

  <category>AI Assistant</category>

  <description><![CDATA[
<p><b>AgentBridge — Bring IntelliJ Code Intelligence to Coding Agents</b></p>

<p>AgentBridge connects coding agents to your JetBrains IDE using MCP and ACP, giving them access to the same tools and feedback that human developers rely on.</p>

<p>Instead of working blindly through a terminal, agents can operate directly through the IDE:</p>
<ul>
  <li>Edit files with full undo, formatting, and VCS integration</li>
  <li>Navigate code using IntelliJ’s code intelligence (PSI)</li>
  <li>Run builds, tests, and git operations through the IDE</li>
  <li>You see files open and update in real time while they work</li>
</ul>

<p>The key difference is the feedback loop.</p>

<p>After every edit, the agent receives immediate feedback from the IDE, including errors, warnings, and inspections (e.g. SonarLint). This allows the agent to correct issues as they appear, instead of discovering them later after multiple changes.</p>

<p>This leads to more stable and maintainable code over longer sessions.</p>

<p><b>Supported agents</b><br>
GitHub Copilot, Claude Code, OpenAI Codex, JetBrains Junie, Amazon Kiro, OpenCode, and Hermes Agent</p>

<p><b>Modes</b></p>
<ul>
  <li>MCP server: connect any external agent</li>
  <li>ACP client: run supported agents directly inside the IDE</li>
</ul>

<p>The plugin runs locally and does not collect or send telemetry.</p>
]]></description>

  <!-- Change-notes are generated at build time by scripts/generate-changelog.sh.
       This static content is used only for local dev builds without CHANGELOG_FILE. -->
  <change-notes><![CDATA[
    <p><b>AgentBridge</b> connects AI coding agents to your IDE via 100+ MCP tools
    for code intelligence, navigation, editing, debugging, and git.</p>
    <p>
      <a href="https://github.com/catatafishen/agentbridge">GitHub</a> ·
      <a href="https://github.com/catatafishen/agentbridge/releases">Release Notes</a>
    </p>
]]></change-notes>

  <!-- Require IntelliJ Platform 2025.3+ (no upper bound) -->
  <idea-version since-build="253"/>

  <!-- Plugin dependencies -->
  <depends>com.intellij.modules.platform</depends>
  <depends optional="true" config-file="java-features.xml">com.intellij.modules.java</depends>
  <depends optional="true" config-file="git-features.xml">Git4Idea</depends>
  <depends optional="true" config-file="terminal-features.xml">org.jetbrains.plugins.terminal</depends>
  <!-- Optional plugins accessed via reflection for enhanced tool support -->
  <depends optional="true" config-file="gradle-features.xml">org.jetbrains.plugins.gradle</depends>
  <depends optional="true" config-file="maven-features.xml">org.jetbrains.idea.maven</depends>
  <depends optional="true" config-file="sonarlint-features.xml">org.sonarlint.idea</depends>
  <depends optional="true" config-file="database-features.xml">com.intellij.database</depends>

  <!-- Extension points and implementations -->
  <extensions defaultExtensionNs="com.intellij">
    <!-- New UI (expui) icon mapping -->
    <iconMapper mappingFile="CopilotBridgeIconMappings.json"/>

    <!-- Tool Window -->
    <toolWindow id="AgentBridge"
                secondary="false"
                anchor="right"
                icon="/icons/agentbridge.svg"
                factoryClass="com.github.catatafishen.agentbridge.ui.ChatToolWindowFactory"/>

    <!-- Application Services -->
    <applicationService
      serviceImplementation="com.github.catatafishen.agentbridge.services.AgentBridgeService"/>
    <applicationService
      serviceImplementation="com.github.catatafishen.agentbridge.settings.ScratchTypeSettings"/>
    <applicationService
      serviceImplementation="com.github.catatafishen.agentbridge.settings.ProjectFilesSettings"/>
    <applicationService
      serviceImplementation="com.github.catatafishen.agentbridge.settings.StartupInstructionsSettings"/>
    <applicationService
      serviceImplementation="com.github.catatafishen.agentbridge.services.AgentProfileManager"/>

    <!-- Project Services -->
    <projectService
      serviceImplementation="com.github.catatafishen.agentbridge.services.ActiveAgentManager"/>
    <projectService
      serviceInterface="com.github.catatafishen.agentbridge.psi.ToolLayerSettings"
      serviceImplementation="com.github.catatafishen.agentbridge.bridge.ActiveAgentToolLayerSettings"/>
    <projectService
      serviceImplementation="com.github.catatafishen.agentbridge.services.ToolRegistry"/>
    <projectService
      serviceImplementation="com.github.catatafishen.agentbridge.services.hooks.HookRegistry"/>
    <projectService
      serviceImplementation="com.github.catatafishen.agentbridge.services.ToolCallTracker"/>
    <projectService
      serviceImplementation="com.github.catatafishen.agentbridge.services.AgentNudgeService"/>
    <projectService
      serviceImplementation="com.github.catatafishen.agentbridge.psi.PsiBridgeService"/>
    <projectService
      serviceImplementation="com.github.catatafishen.agentbridge.settings.McpServerSettings"/>
    <projectService
      serviceImplementation="com.github.catatafishen.agentbridge.settings.ChatWebServerSettings"/>
    <projectService
      serviceImplementation="com.github.catatafishen.agentbridge.settings.ChatHistorySettings"/>
    <projectService
      serviceImplementation="com.github.catatafishen.agentbridge.services.ChatWebServer"/>

    <!-- MCP HTTP server (speaks MCP protocol, used by agent CLI via McpStdioProxy) -->
    <projectService
      serviceInterface="com.github.catatafishen.agentbridge.services.McpServerControl"
      serviceImplementation="com.github.catatafishen.agentbridge.services.McpHttpServer"/>

    <!-- Session migration service (exports v2 session to native format on agent switch) -->
    <projectService
      serviceImplementation="com.github.catatafishen.agentbridge.session.SessionSwitchService"/>

    <!-- Agent resource cleanup services -->
    <projectService
      serviceImplementation="com.github.catatafishen.agentbridge.services.CleanupSettings"/>
    <projectService
      serviceImplementation="com.github.catatafishen.agentbridge.services.AgentTabTracker"/>
    <projectService
      serviceImplementation="com.github.catatafishen.agentbridge.services.AgentScratchTracker"/>

    <!-- Semantic memory service + settings -->
    <projectService
      serviceImplementation="com.github.catatafishen.agentbridge.memory.MemorySettings"/>
    <projectService
      serviceImplementation="com.github.catatafishen.agentbridge.memory.MemoryService"/>
    <projectService
      serviceImplementation="com.github.catatafishen.agentbridge.memory.mining.MiningTracker"/>

    <!-- Memory mining status bar indicator -->
    <statusBarWidgetFactory
      id="AgentBridge.MemoryMining"
      implementation="com.github.catatafishen.agentbridge.memory.mining.MiningStatusBarWidgetFactory"/>

    <!-- Custom external MCP server proxy -->
    <projectService
      serviceImplementation="com.github.catatafishen.agentbridge.custommcp.CustomMcpSettings"/>
    <projectService
      serviceImplementation="com.github.catatafishen.agentbridge.custommcp.CustomMcpRegistrar"/>

    <!-- Registry for temporary external-dir modules (attach_external_dir / detach_external_dir) -->
    <projectService
      serviceImplementation="com.github.catatafishen.agentbridge.psi.tools.project.ExternalDirRegistry"/>

    <!-- Live tool call tracking for the Tools tab in the side panel -->
    <projectService
      serviceImplementation="com.github.catatafishen.agentbridge.services.LiveToolCallService"/>

    <!-- Pause/resume service — defers MCP tool calls while the user has paused the agent -->
    <projectService
      serviceImplementation="com.github.catatafishen.agentbridge.services.McpPauseService"/>

    <!-- Bridges query_turns MCP tool → Prompts side panel for follow-agent navigation -->
    <projectService
      serviceImplementation="com.github.catatafishen.agentbridge.services.PromptDbService"/>

    <!-- Agent edit review session (diff tracking, revert-with-nudge) -->
    <projectService
      serviceImplementation="com.github.catatafishen.agentbridge.psi.review.AgentEditSession"/>
    <projectService
      serviceImplementation="com.github.catatafishen.agentbridge.psi.review.AgentEditHighlighter"/>
    <projectService
      serviceImplementation="com.github.catatafishen.agentbridge.ui.review.ReviewPanelController"/>
    <editorNotificationProvider
      implementation="com.github.catatafishen.agentbridge.psi.review.AgentEditNotificationProvider"/>

    <!-- Settings: AgentBridge (root) -->
    <projectConfigurable
      parentId="tools"
      instance="com.github.catatafishen.agentbridge.settings.PluginSettingsConfigurable"
      id="com.github.catatafishen.agentbridge.settings"
      displayName="AgentBridge"/>

    <!-- ── UI/UX ── -->
    <projectConfigurable
      parentId="com.github.catatafishen.agentbridge.settings"
      instance="com.github.catatafishen.agentbridge.settings.ChatInputConfigurable"
      id="com.github.catatafishen.agentbridge.chatInput"
      displayName="UI/UX"/>

    <!-- ── Chat History (under Storage) ── -->
    <projectConfigurable
      parentId="com.github.catatafishen.agentbridge.storage"
      instance="com.github.catatafishen.agentbridge.settings.ChatHistoryConfigurable"
      id="com.github.catatafishen.agentbridge.chatHistory"
      displayName="Chat History"/>

    <!-- ── MCP section (server config + child pages) ── -->
    <projectConfigurable
      parentId="com.github.catatafishen.agentbridge.settings"
      instance="com.github.catatafishen.agentbridge.settings.McpGroupConfigurable"
      id="com.github.catatafishen.agentbridge.mcp"
      displayName="MCP"/>

    <projectConfigurable
      parentId="com.github.catatafishen.agentbridge.mcp"
      instance="com.github.catatafishen.agentbridge.settings.ToolsConfigurable"
      id="com.github.catatafishen.agentbridge.mcp.tools"
      displayName="Tools"/>

    <projectConfigurable
      parentId="com.github.catatafishen.agentbridge.mcp"
      instance="com.github.catatafishen.agentbridge.settings.ToolPermissionsConfigurable"
      id="com.github.catatafishen.agentbridge.toolPermissions"
      displayName="Tool Permissions"/>

    <projectConfigurable
      parentId="com.github.catatafishen.agentbridge.mcp"
      instance="com.github.catatafishen.agentbridge.custommcp.CustomMcpConfigurable"
      id="com.github.catatafishen.agentbridge.mcp.customServers"
      displayName="Custom Servers"/>

    <!-- ── Agents section (session behavior + instructions + client pages) ── -->
    <projectConfigurable
      parentId="com.github.catatafishen.agentbridge.settings"
      instance="com.github.catatafishen.agentbridge.settings.ClientAgentsGroupConfigurable"
      id="com.github.catatafishen.agentbridge.clientAgents"
      displayName="Agents"/>

    <projectConfigurable
      parentId="com.github.catatafishen.agentbridge.clientAgents"
      instance="com.github.catatafishen.agentbridge.settings.CopilotClientConfigurable"
      id="com.github.catatafishen.agentbridge.clientAgents.copilot"
      displayName="GitHub Copilot"/>

    <projectConfigurable
      parentId="com.github.catatafishen.agentbridge.clientAgents"
      instance="com.github.catatafishen.agentbridge.settings.OpenCodeClientConfigurable"
      id="com.github.catatafishen.agentbridge.clientAgents.opencode"
      displayName="OpenCode"/>

    <projectConfigurable
      parentId="com.github.catatafishen.agentbridge.clientAgents"
      instance="com.github.catatafishen.agentbridge.settings.ClaudeCliClientConfigurable"
      id="com.github.catatafishen.agentbridge.clientAgents.claudeCli"
      displayName="Claude CLI"/>

    <projectConfigurable
      parentId="com.github.catatafishen.agentbridge.clientAgents"
      instance="com.github.catatafishen.agentbridge.settings.JunieClientConfigurable"
      id="com.github.catatafishen.agentbridge.clientAgents.junie"
      displayName="Junie"/>

    <projectConfigurable
      parentId="com.github.catatafishen.agentbridge.clientAgents"
      instance="com.github.catatafishen.agentbridge.settings.KiroClientConfigurable"
      id="com.github.catatafishen.agentbridge.clientAgents.kiro"
      displayName="Kiro"/>

    <projectConfigurable
      parentId="com.github.catatafishen.agentbridge.clientAgents"
      instance="com.github.catatafishen.agentbridge.settings.HermesClientConfigurable"
      id="com.github.catatafishen.agentbridge.clientAgents.hermes"
      displayName="Hermes Agent"/>

    <projectConfigurable
      parentId="com.github.catatafishen.agentbridge.clientAgents"
      instance="com.github.catatafishen.agentbridge.settings.CodexClientConfigurable"
      id="com.github.catatafishen.agentbridge.clientAgents.codex"
      displayName="Codex"/>

    <!-- ── Storage (file locations + child stores: tool stats, memory, chat history) ── -->
    <projectConfigurable
      parentId="com.github.catatafishen.agentbridge.settings"
      instance="com.github.catatafishen.agentbridge.settings.AgentBridgeStorageConfigurable"
      id="com.github.catatafishen.agentbridge.storage"
      displayName="Storage"/>

    <projectConfigurable
      parentId="com.github.catatafishen.agentbridge.storage"
      instance="com.github.catatafishen.agentbridge.settings.ToolStatsConfigurable"
      id="com.github.catatafishen.agentbridge.storage.toolStats"
      displayName="Tool Statistics"/>

    <!-- ── Project Files ── -->
    <projectConfigurable
      parentId="com.github.catatafishen.agentbridge.settings"
      instance="com.github.catatafishen.agentbridge.settings.ProjectFilesConfigurable"
      id="com.github.catatafishen.agentbridge.projectFiles"
      displayName="Project Files"/>

    <!-- ── Scratch File Types ── -->
    <projectConfigurable
      parentId="com.github.catatafishen.agentbridge.settings"
      instance="com.github.catatafishen.agentbridge.settings.ScratchTypesConfigurable"
      id="com.github.catatafishen.agentbridge.scratchTypes"
      displayName="Scratch File Types"/>

    <!-- ── Memory (semantic memory / MemPalace, under Storage) ── -->
    <projectConfigurable
      parentId="com.github.catatafishen.agentbridge.storage"
      instance="com.github.catatafishen.agentbridge.memory.MemorySettingsConfigurable"
      id="com.github.catatafishen.agentbridge.memory"
      displayName="Memory"/>

    <!-- ── Web Access ── -->
    <projectConfigurable
      parentId="com.github.catatafishen.agentbridge.settings"
      instance="com.github.catatafishen.agentbridge.settings.ChatWebServerConfigurable"
      id="com.github.catatafishen.agentbridge.webAccess"
      displayName="Web Access"/>

    <!-- Start PSI Bridge when the project opens -->
    <postStartupActivity
      implementation="com.github.catatafishen.agentbridge.psi.PsiBridgeStartup"/>

    <!-- Connect to custom external MCP servers when the project opens -->
    <postStartupActivity
      implementation="com.github.catatafishen.agentbridge.custommcp.CustomMcpStartupActivity"/>

    <!-- Notification Group for status messages -->
    <notificationGroup id="AgentBridge Notifications" displayType="STICKY_BALLOON"/>

    <!-- Project View decorator showing agent file access (read/edited) -->
    <projectViewNodeDecorator
      implementation="com.github.catatafishen.agentbridge.psi.AgentFileDecorator"/>
  </extensions>

  <actions>
    <action id="AgentBridge.Prompt.Send"
            class="com.github.catatafishen.agentbridge.ui.PromptShortcutAction"
            text="Send Prompt"
            description="Send the current prompt text (or nudge if the agent is working)">
      <keyboard-shortcut keymap="$default" first-keystroke="ENTER"/>
    </action>
    <action id="AgentBridge.Prompt.NewLine"
            class="com.github.catatafishen.agentbridge.ui.PromptShortcutAction"
            text="New Line"
            description="Insert a new line in the chat prompt">
      <keyboard-shortcut keymap="$default" first-keystroke="shift ENTER"/>
    </action>
    <action id="AgentBridge.Prompt.StopAndSend"
            class="com.github.catatafishen.agentbridge.ui.PromptShortcutAction"
            text="Stop and Send"
            description="Force-stop the current agent work and send the prompt">
      <keyboard-shortcut keymap="$default" first-keystroke="ctrl ENTER"/>
    </action>
    <action id="AgentBridge.Prompt.Queue"
            class="com.github.catatafishen.agentbridge.ui.PromptShortcutAction"
            text="Queue Message"
            description="Queue the prompt to be sent after the agent finishes current work">
      <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift ENTER"/>
    </action>
    <action id="AgentBridge.Prompt.ShowShortcuts"
            class="com.github.catatafishen.agentbridge.ui.PromptShortcutAction"
            text="Show Keyboard Shortcuts"
            description="Show all available chat prompt keyboard shortcuts">
      <keyboard-shortcut keymap="$default" first-keystroke="ctrl SLASH"/>
    </action>
    <action id="AgentBridge.ForceJcefRefresh"
            class="com.github.catatafishen.agentbridge.ui.ForceJcefRefreshAction"
            text="AgentBridge: Force JCEF Refresh"
            description="Diagnostic: force the chat panel to re-query its display scale and rebuild its OSR surface (recovers from monitor-switch freezes; issue #237)"/>
    <action id="AgentBridge.Review.RevertAgentEdits"
            class="com.github.catatafishen.agentbridge.psi.review.RevertAgentEditsAction"
            text="Revert Agent Edits"
            description="Restore this file to its state before the current agent review session, optionally sending a reason as a nudge">
      <add-to-group group-id="EditorPopupMenu" anchor="last"/>
      <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
    </action>
    <action id="AgentBridge.Review.NextChange"
            class="com.github.catatafishen.agentbridge.psi.review.NextAgentEditChangeAction"
            text="Next Agent Edit Change"
            description="Jump to the next agent-edited change across the review session">
      <add-to-group group-id="EditorPopupMenu" anchor="last"/>
    </action>
    <action id="AgentBridge.Review.PreviousChange"
            class="com.github.catatafishen.agentbridge.psi.review.PreviousAgentEditChangeAction"
            text="Previous Agent Edit Change"
            description="Jump to the previous agent-edited change across the review session">
      <add-to-group group-id="EditorPopupMenu" anchor="last"/>
    </action>
    <action id="AgentBridge.Review.ShowRangeDiff"
            class="com.github.catatafishen.agentbridge.psi.review.ShowRangeDiffAction"
            text="Show Agent Edit Diff Here"
            description="Open an inline diff popup for the agent-edit change at the caret">
      <add-to-group group-id="EditorPopupMenu" anchor="last"/>
    </action>
  </actions>
</idea-plugin>
